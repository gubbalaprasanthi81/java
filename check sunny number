import java.util.Scanner;

public class SunnyNumber {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();

        int x = n + 1;
        int root = (int)Math.sqrt(x);

        System.out.println(root * root == x ? "Sunny" : "Not Sunny");
    }
}

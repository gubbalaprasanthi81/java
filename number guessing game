import java.util.*;

public class GuessGame {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Random r = new Random();

        int num = r.nextInt(100);
        int guess;

        do {
            guess = sc.nextInt();

            if (guess > num)
                System.out.println("Too High");
            else if (guess < num)
                System.out.println("Too Low");
            else
                System.out.println("Correct!");

        } while (guess != num);
    }
}

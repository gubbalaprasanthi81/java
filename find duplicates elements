import java.util.HashSet;

public class Duplicates {
    public static void main(String[] args) {
        int[] arr = {1,2,3,2,4,1};
        HashSet<Integer> set = new HashSet<>();

        for (int n : arr) {
            if (!set.add(n))
                System.out.print(n + " ");
        }
    }
}

import java.util.Scanner;

public class PrimeRange {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int start = sc.nextInt();
        int end = sc.nextInt();

        for (int i = start; i <= end; i++) {
            int count = 0;
            for (int j = 2; j <= Math.sqrt(i); j++)
                if (i % j == 0) count++;

            if (i > 1 && count == 0)
                System.out.print(i + " ");
        }
    }
}
